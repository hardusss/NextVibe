# Service
PORT=3000
NODE_ENV=production
INTERNAL_SECRET=change_me_to_random_32_char_secret

# MySQL — same database as Django (use URL or individual vars)
MYSQL_URL=mysql://indexer:your_password@localhost:3306/your_database_name
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=indexer
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=your_database_name
# MYSQL_SSL=true

# Django users table (default: user_user)
# USERS_TABLE=user_user

# Redis
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Helius
HELIUS_API_KEY=your_helius_api_key
HELIUS_WEBHOOK_ID=your_webhook_id
HELIUS_WEBHOOK_SECRET=your_webhook_secret
HELIUS_WEBHOOK_URL=https://your-server.com/webhook/helius

# Fetch limits
INITIAL_FETCH_LIMIT=10
LOAD_MORE_DEFAULT_LIMIT=50
